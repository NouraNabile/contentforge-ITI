# ── ContentForge Backend — copy this to .env and fill in your values ──────────

PORT=3000
NODE_ENV=development

# MongoDB Atlas connection string
# Get from: MongoDB Atlas → your cluster → Connect → Drivers   
MONGODB_URI=your_mongodb_uri_here
# Google Gemini API key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# JWT secret — change this to any long random string in production
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Your Vue frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

#Meta API Key
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here
META_REDIRECT_URI=http://localhost:3000/api/connections/meta/callback