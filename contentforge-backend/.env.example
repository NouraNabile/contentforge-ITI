# ── ContentForge Backend — copy this to .env and fill in your values ──────────

PORT=3000
NODE_ENV=development

# MongoDB Atlas connection string
# Get from: MongoDB Atlas → your cluster → Connect → Drivers   
MONGODB_URI=your_mongodb_uri_here
# Google Gemini API key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here
HF_API_TOKEN=your_huggingface_api_token_here
# JWT secret — change this to any long random string in production
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
    
EMAIL_PASS=""
EMAIL_USER="your_email@gmail.com"
ADMIN_EMAIL="your-admin@gmail.com"
# Your Vue frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

#Meta API Key
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here
META_REDIRECT_URI=http://localhost:3000/api/connections/meta/callback

# ── Stripe ────────────────────────────────────────────────────────────────────
# من Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# من Stripe Dashboard → Products → كل product بيدي Price ID
STRIPE_STARTER_MONTHLY=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_STARTER_ANNUAL=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_GROWTH_MONTHLY=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_GROWTH_ANNUAL=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_AGENCY_MONTHLY=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_AGENCY_ANNUAL=price_xxxxxxxxxxxxxxxxxxxx

STRIPE_Pro_MONTHLY=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_Pro_ANNUAL=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_Enterprise_MONTHLY=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_Enterprise_ANNUAL=price_xxxxxxxxxxxxxxxxxxxx
# من Stripe Dashboard → Developers → Webhooks → Add endpoint
# الـ endpoint URL: https://yourapi.com/api/payment/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

REMOVE_BG_API_KEY=your_remove_bg_api_key_here