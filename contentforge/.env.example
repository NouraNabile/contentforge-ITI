# ─── ContentForge Frontend Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it's already in .gitignore

# ── Backend API URL ──────────────────────────────────────────────────────────
# Development (local backend running on port 3000)
VITE_API_URL=http://localhost:3000/api

# Production (uncomment when deployed to Render)
# VITE_API_URL=https://contentforge-api.onrender.com/api

# ── App name (optional) ──────────────────────────────────────────────────────
VITE_APP_NAME=ContentForge
